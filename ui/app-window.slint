import { Button, VerticalBox } from "std-widgets.slint";
import { PatternEditor } from "pattern_editor.slint";

component PlayButton inherits Button {
    width: 100px;
    height: 40px;
    text: "Play";
}
export component MainWindow inherits Window {
    min-width: 400px;
    preferred-height: 500px;
    title: "Composable: Pluggable DAW";
    callback play_midi();

    in property<bool> is_playing;

    VerticalBox {
        alignment: center;
        spacing: 5px;
        PatternEditor {
            width: 512px;
            height: 384px;
        }
        PlayButton {
            enabled: !is_playing;
            clicked => {
                root.play_midi();
            }
        }
    }
}

